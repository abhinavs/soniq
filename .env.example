# .env.example — Copy to .env and fill in your values

# Required
SONIQ_DATABASE_URL=postgresql://soniq:password@localhost/soniq
SONIQ_JOBS_MODULES=myapp.jobs

# Worker
SONIQ_CONCURRENCY=4
SONIQ_QUEUES=default

# Recommended for production
SONIQ_LOG_LEVEL=INFO
SONIQ_TIMEOUTS_ENABLED=true
SONIQ_DEAD_LETTER_QUEUE_ENABLED=true
SONIQ_RESULT_TTL=300

# Optional features
# SONIQ_DASHBOARD_ENABLED=true
# SONIQ_SCHEDULING_ENABLED=true
# SONIQ_METRICS_ENABLED=true
# SONIQ_WEBHOOKS_ENABLED=true
